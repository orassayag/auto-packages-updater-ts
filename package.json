{
  "name": "auto-packages-updater-ts",
  "version": "1.0.0",
  "private": false,
  "description": "A Node.js automation tool to scan multiple projects for outdated NPM/PNPM packages and automatically update them with Git integration. This application reads project configurations from an external JSON file, checks for the packages across multiple projects simultaneously, generates detailed report",
  "keywords": [
    "nodejs",
    "automation",
    "npm",
    "pnpm",
    "package-updater",
    "dependency-checker",
    "outdated-packages",
    "git-integration",
    "version-management",
    "project-scanner",
    "multi-project",
    "json-config",
    "report-generation",
    "dependency-updates",
    "devtools",
    "ci-ready",
    "local-development",
    "repository",
    "maintenance",
    "update-tool"
  ],
  "homepage": "https://github.com/orassayag/auto-packages-updater-ts#readme",
  "bugs": {
    "url": "https://github.com/orassayag/auto-packages-updater-ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/orassayag/auto-packages-updater-ts.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/orassayag"
  },
  "license": "MIT",
  "author": {
    "name": "Or Assayag",
    "email": "orassayag@gmail.com",
    "url": "https://github.com/orassayag"
  },
  "contributors": [
    {
      "name": "Or Assayag",
      "email": "orassayag@gmail.com",
      "url": "https://github.com/orassayag"
    }
  ],
  "type": "module",
  "main": "src/index.ts",
  "files": [
    ".github",
    ".vscode",
    "dist",
    "docs",
    "logs",
    "misc",
    "src",
    ".gitignore",
    ".npmrc",
    ".prettierrc",
    "auto-packages-updater-ts.bat",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "eslint.config.mjs",
    "INSTRUCTIONS.md",
    "LICENSE",
    "package.json",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "README.md",
    "SECURITY.md",
    "tsconfig.json",
    "tsconfig.node.json",
    "vitest.config.ts"
  ],
  "scripts": {
    "build": "tsc",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "start": "tsx src/index.ts",
    "sync": "tsx src/index.ts --auto",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.5",
    "inversify": "^8.1.1",
    "latest-version": "^9.0.0",
    "ora": "^9.4.1",
    "reflect-metadata": "^0.2.2",
    "semver": "^7.8.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rolldown/binding-win32-x64-msvc": "^1.1.3",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^26.0.0",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-istanbul": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
